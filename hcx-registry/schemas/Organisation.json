{
   "$schema":"http://json-schema.org/draft-07/schema",
   "$id":"https://schemas.healthflow.eg/registry/Organisation.json",
   "type":"object",
   "properties":{
      "Organisation":{
         "$ref":"#/definitions/Organisation"
      }
   },
   "required":[
      "Organisation"
   ],
   "title":"Organisation",
   "definitions":{
      "Organisation":{
         "$id":"#/definitions/Organisation",
         "type":"object",
         "title":"The Organisation Schema (HealthFlow Egypt)",
         "required":[
            "participant_code",
            "participant_name",
            "roles",
            "primary_mobile",
            "status",
            "encryption_cert",
            "endpoint_url"
         ],
         "properties":{
            "participant_code":{
               "type":"string"
            },
            "participant_name":{
               "type":"string"
            },
            "roles":{
               "type":"array",
               "items":{
                  "type":"string",
                  "enum":[
                     "provider",
                     "payor",
                     "agency.tpa",
                     "agency.bsp",
                     "agency.regulator.fra",
                     "agency.regulator.mohp",
                     "agency.regulator.eda",
                     "research",
                     "agency.sponsor",
                     "hie.healthflow"
                  ]
               }
            },
            "linked_registry_codes":{
               "type":"array",
               "items":{
                  "type":"string"
               }
            },
            "scheme_code":{
               "type":"string",
               "default":"default"
            },
            "address":{
               "$ref":"#/definitions/address"
            },
            "national_id":{
               "type":"string",
               "pattern":"^[0-9]{14}$",
               "description":"Egyptian National ID of the legal-entity owner / authorized signatory. 14 digits. The EgyptianNationalIDValidator additionally enforces governorate-code prefix and the Luhn checksum at the API layer (P0-4b)."
            },
            "primary_email":{
               "type":"string",
               "format":"email"
            },
            "additional_email":{
               "type":"array",
               "items":{
                  "type":"string",
                  "format":"email"
               },
               "maxItems":2
            },
            "phone":{
               "type":"array",
               "items":{
                  "type":"string"
               },
               "maxItems":3
            },
            "primary_mobile":{
               "type":"string"
            },
            "additional_mobile":{
               "type":"array",
               "items":{
                  "type":"string"
               },
               "maxItems":2
            },
            "status":{
               "type":"string",
               "enum":[
                  "Created",
                  "Active",
                  "Inactive",
                  "Blocked"
               ]
            },
            "signing_cert_path":{
               "type":"string",
               "format":"uri"
            },
            "encryption_cert":{
               "type":"string",
               "format":"uri"
            },
            "endpoint_url":{
               "type":"string",
               "format":"url"
            },
            "payment_details":{
               "type":"object",
               "description":"Egyptian banking identifiers. Provide either an IBAN+BIC pair (for inter-bank transfers) or a Meeza wallet card number (for retail payouts).",
               "properties":{
                  "iban":{
                     "type":"string",
                     "pattern":"^EG[0-9]{27}$",
                     "description":"Egyptian IBAN, 29 characters: 'EG' followed by 27 digits. Mod-97 checksum is enforced by the EgyptianIBANValidator at the API layer."
                  },
                  "bic":{
                     "type":"string",
                     "pattern":"^[A-Z]{6}[A-Z0-9]{2}([A-Z0-9]{3})?$",
                     "description":"ISO 9362 Bank Identifier Code (SWIFT). 8 or 11 characters."
                  },
                  "meeza_card":{
                     "type":"string",
                     "pattern":"^[0-9]{16}$",
                     "description":"Meeza wallet card number, 16 digits."
                  }
               },
               "oneOf":[
                  {
                     "required":[
                        "iban",
                        "bic"
                     ]
                  },
                  {
                     "required":[
                        "meeza_card"
                     ]
                  }
               ]
            }
         }
      },
      "address":{
         "type":"object",
         "description":"Egyptian street address. Postal code follows the 5-digit Egyptian system; the governorate field must be one of the 27 official governorates and stays in sync with the EgyptianGovernorate enum at the API layer. additionalProperties is disabled so that legacy locale-specific fields from the upstream schema cannot be smuggled in via the registry write path.",
         "additionalProperties":false,
         "required":[
            "governorate",
            "postal_code"
         ],
         "properties":{
            "building":{
               "type":"string"
            },
            "street":{
               "type":"string"
            },
            "landmark":{
               "type":"string"
            },
            "shiakha":{
               "type":"string",
               "description":"Neighborhood / shiakha"
            },
            "markaz":{
               "type":"string",
               "description":"Markaz (district / sub-governorate administrative division)"
            },
            "governorate":{
               "type":"string",
               "enum":[
                  "Cairo",
                  "Giza",
                  "Alexandria",
                  "Qalyubia",
                  "Port Said",
                  "Suez",
                  "Ismailia",
                  "Dakahlia",
                  "Sharqia",
                  "Gharbia",
                  "Monufia",
                  "Beheira",
                  "Kafr El Sheikh",
                  "Damietta",
                  "Fayoum",
                  "Beni Suef",
                  "Minya",
                  "Asyut",
                  "Sohag",
                  "Qena",
                  "Aswan",
                  "Luxor",
                  "Red Sea",
                  "New Valley",
                  "Matrouh",
                  "North Sinai",
                  "South Sinai"
               ]
            },
            "postal_code":{
               "type":"string",
               "pattern":"^[0-9]{5}$"
            }
         }
      }
   },
   "_osConfig":{
      "ownershipAttributes":[
         {
            "email":"/primary_email",
            "mobile":"/primary_mobile",
            "userId":"/primary_email"
         }
      ],
      "uniqueIndexFields":[
         "participant_code",
         "primary_email",
         "national_id"
      ]
   }
}
