# HealthFlow Egypt deployment environment variables
# Copy this file to `.env` in the same directory and fill in real values
# before running `docker compose -f docker-compose-egypt.yml up`.

# Postgres
# Used by hcx-postgres (server bootstrap), hcx-api, and hcx-keycloak.
# All three must agree — they connect to the same Postgres instance.
POSTGRES_USER=hcx_admin
POSTGRES_PASSWORD=replace-me-strong-password

# Provider service Keycloak client secret
# Optional — defaults to the placeholder `provider-secret` used by the
# bundled hcx-egypt realm import. Override in any non-dev environment with
# the real client secret minted in Keycloak.
PROVIDER_SERVICE_CLIENT_SECRET=replace-me-from-keycloak-client
