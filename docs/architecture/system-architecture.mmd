graph TB
    subgraph "Participant Layer"
        PP[Provider Portal<br/>hcx-apps]
        PayP[Payer Portal<br/>hcx-apps]
        TPAP[TPA Portal<br/>hcx-apps]
        BSP[Beneficiary Portal<br/>hcx-apps]
        AP[Admin Portal<br/>hcx-apps]
    end

    subgraph "API Gateway Layer"
        AG[API Gateway<br/>hfcx-platform]
        AUTH[Authentication<br/>Keycloak]
        RL[Rate Limiting]
        LB[Load Balancer]
    end

    subgraph "Core Business Logic Layer"
        EV[Eligibility<br/>Verification]
        PA[Pre-Authorization<br/>Processing]
        CP[Claims<br/>Processing]
        CE[Communication<br/>Exchange]
        PN[Payment<br/>Notifications]
        WE[Workflow<br/>Engine]
    end

    subgraph "Integration Layer"
        PS[Provider Service<br/>provider-service]
        SDK[Integration SDKs<br/>integration-sdks]
        JWE[JWE Helper<br/>jwe-helper]
    end

    subgraph "Registry Layer"
        REG[Participant Registry<br/>sunbird-rc-core]
        CRED[Verifiable Credentials]
        PKI[Public Key Infrastructure]
    end

    subgraph "Data Layer"
        PG[(PostgreSQL<br/>Database)]
        RD[(Redis<br/>Cache)]
        KF[(Kafka<br/>Message Queue)]
    end

    subgraph "Monitoring Layer"
        PROM[Prometheus<br/>Metrics]
        GRAF[Grafana<br/>Dashboards]
        JAEG[Jaeger<br/>Tracing]
        ELK[ELK Stack<br/>Logging]
    end

    subgraph "External Systems"
        HIS[Hospital Information<br/>Systems]
        PAYER[Payer Claims<br/>Systems]
        TPA[TPA Admin<br/>Systems]
    end

    %% Connections
    PP --> AG
    PayP --> AG
    TPAP --> AG
    BSP --> AG
    AP --> AG

    AG --> AUTH
    AG --> RL
    AG --> LB

    AG --> EV
    AG --> PA
    AG --> CP
    AG --> CE
    AG --> PN
    AG --> WE

    EV --> PG
    PA --> PG
    CP --> PG
    CE --> PG
    PN --> PG
    WE --> KF

    EV --> RD
    PA --> RD
    CP --> RD

    AG --> REG
    REG --> CRED
    REG --> PKI

    PS --> AG
    SDK --> AG
    JWE --> AG

    HIS --> PS
    PAYER --> SDK
    TPA --> SDK

    AG --> PROM
    AG --> JAEG
    AG --> ELK
    PROM --> GRAF

